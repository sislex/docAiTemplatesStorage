{
  "$schema": "../../node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "ui-kit": {
      "projectType": "library",
      "root": "",
      "sourceRoot": "src",
      "prefix": "ts",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "options": {
            "project": "ng-package.json",
            "tsConfig": "tsconfig.lib.json"
          }
        },
        "storybook-host": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": "dist/sb-host",
            "index": "src/storybook-index.html",
            "browser": "src/storybook-host.ts",
            "tsConfig": "tsconfig.sb.json"
          }
        },
        "storybook": {
          "builder": "@storybook/angular:start-storybook",
          "options": {
            "configDir": ".storybook",
            "browserTarget": "ui-kit:storybook-host",
            "port": 6006,
            "compodoc": false
          }
        },
        "build-storybook": {
          "builder": "@storybook/angular:build-storybook",
          "options": {
            "configDir": ".storybook",
            "browserTarget": "ui-kit:storybook-host",
            "outputDir": "storybook-static",
            "compodoc": false
          }
        }
      }
    }
  }
}
