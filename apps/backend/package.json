{
  "name": "@templateStorage/backend",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build:deps": "npm --prefix ../../packages/shared-types run build && npm --prefix ../../packages/ai-assistant-backend run build",
    "dev": "npm run build:deps && nest start --watch",
    "build": "npm run build:deps && nest build",
    "start": "npm run build:deps && node dist/main",
    "test": "jest",
    "test:e2e": "jest --config test/jest-e2e.json",
    "test:cov": "jest --coverage",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix"
  },
  "dependencies": {
    "@templateStorage/ai-assistant-backend": "0.0.1",
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/swagger": "^7.4.2",
    "async-mutex": "^0.5.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.6.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/testing": "^10.4.15",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.12",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.17.9",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.0"
  }
}
